# terraform.tfvars.example — Copy to terraform.tfvars and fill in your values.
#
# terraform.tfvars is gitignored (contains sensitive credentials).

oci_tenancy_ocid     = "ocid1.tenancy.oc1..REPLACE_ME"
oci_user_ocid        = "ocid1.user.oc1..REPLACE_ME"
oci_fingerprint      = "aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99"
oci_private_key_path = "~/.oci/oci_api_key.pem"
oci_region           = "eu-amsterdam-1"
oci_compartment_ocid = "ocid1.compartment.oc1..REPLACE_ME"
